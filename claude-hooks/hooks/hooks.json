{
  "description": "ClickMem hooks — captures conversations and injects long-term memory context",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://100.86.126.80:9527/hooks/claude-code",
            "timeout": 30
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "http",
            "url": "http://100.86.126.80:9527/hooks/claude-code",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST -H 'Content-Type: application/json' -d @- http://100.86.126.80:9527/hooks/claude-code",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "curl -s -X POST -H 'Content-Type: application/json' -d @- http://100.86.126.80:9527/hooks/claude-code",
            "timeout": 60,
            "async": true
          }
        ]
      }
    ]
  }
}
